# =============================================================================
#  VPN-shop base — environment
#  Copy to `.env` and fill in.  Config is validated at startup (src/core/config)
#  — placeholder values like "change_me" are REJECTED, not silently accepted.
# =============================================================================

# --- App -------------------------------------------------------------------
APP__ENV=local                       # local | staging | production
APP__DEBUG=true
# 44-char urlsafe base64 Fernet key (encrypts gateway credentials at rest).
# Generate:  python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
APP__CRYPT_KEY=
# Distinct from CRYPT_KEY. Used to sign cabinet/mini-app JWTs (added with the web cabinet later).
APP__JWT_SECRET=
# Telegram user ids that get the OWNER role on first contact (comma-separated).
APP__OWNER_IDS=

# --- Bot -------------------------------------------------------------------
BOT__TOKEN=                          # from @BotFather
BOT__USE_WEBHOOK=false               # false = long polling (dev), true = webhook (prod)
BOT__WEBHOOK_BASE=                   # https://your.domain (required when USE_WEBHOOK=true)
BOT__WEBHOOK_SECRET=                 # secret-token header, verified constant-time

# --- Admin cabinet (web SPA login) -----------------------------------------
# Both must be set — bootstrap creates/updates this OWNER account at startup.
# Without them there is NO admin login.
ADMIN__USERNAME=root_admin
ADMIN__PASSWORD=                     # pick a strong password

# --- Database (PostgreSQL) -------------------------------------------------
DATABASE__HOST=postgres
DATABASE__PORT=5432
DATABASE__USER=vpn
DATABASE__PASSWORD=
DATABASE__NAME=vpn
DATABASE__POOL_SIZE=10

# --- Redis -----------------------------------------------------------------
REDIS__HOST=redis
REDIS__PORT=6379
REDIS__DB=0
REDIS__PASSWORD=

# --- Remnawave panel -------------------------------------------------------
REMNAWAVE__BASE_URL=https://panel.example.com      # panel base URL (http:// for local/docker network)
REMNAWAVE__AUTH_TYPE=api_key                        # api_key | bearer | basic | caddy
REMNAWAVE__TOKEN=                                    # api key / bearer token (sent as BOTH X-Api-Key and Bearer)
REMNAWAVE__BASIC_USER=                               # only for AUTH_TYPE=basic
REMNAWAVE__BASIC_PASSWORD=
REMNAWAVE__CADDY_API_KEY=                            # only when panel is behind Caddy secret-key
REMNAWAVE__CF_ACCESS_CLIENT_ID=                      # optional Cloudflare Access
REMNAWAVE__CF_ACCESS_CLIENT_SECRET=
REMNAWAVE__SECRET_KEY_COOKIE=                        # optional "name:value" cookie set by nginx/Caddy
REMNAWAVE__WEBHOOK_SECRET=                           # HMAC secret for inbound panel webhooks
# Leave empty to auto-detect: bare host / private IP / docker service name => treat as LOCAL
# (http + X-Forwarded-* injection + TLS verify off). Set to force.
REMNAWAVE__FORCE_LOCAL=

# --- Web (webhooks + health + cabinet/mini-app API) ------------------------
WEB__HOST=0.0.0.0
WEB__PORT=8080
# Public https base URL the whole app is reachable at, e.g. https://vpn.example.com
# On first boot this AUTO-WIRES the bot <-> mini-app link: the bot's mini-app button and the web
# cabinet point at <URL>/app and <URL>, with NO manual config. (Telegram Mini Apps require HTTPS,
# so an http://IP won't show the button.) install.sh fills this from the domain you enter.
WEB__PUBLIC_URL=
# Explicit origins for the future cabinet (NEVER "*" once cookie auth is on — it disables credentials).
WEB__CORS_ORIGINS=

# --- Logging ---------------------------------------------------------------
LOG__LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR
LOG__USE_JSON=false                  # true = JSON logs (prod)

# --- Crash telemetry (docs/TELEMETRY.md) -------------------------------------
# Необработанные ошибки уходят на СВОЙ сервер приёма (см. telemetry-server/) —
# без данных юзеров: класс ошибки, трейс без путей, версия и анонимный id установки.
# По умолчанию URL пуст => телеметрия выключена, пока не укажешь свой адрес.
TELEMETRY__ENABLED=true              # false = выключить принудительно
#TELEMETRY__URL=https://errors.example.com/ingest
#TELEMETRY__TOKEN=                   # общий секрет, если приём за токеном
